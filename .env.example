# gopherguard environment configuration
#
# Copy this file to `.env` and fill in values as needed:
#   cp .env.example .env
#
# `.env` is gitignored and must NEVER be committed. Secrets are injected at
# runtime (local dev) or pulled from Secret Manager in production — this repo
# never ships committed credentials.

# Google AI Studio / Gemini API key. Leave empty to run fully offline against
# local Gemma via Ollama. Setting this (together with GG_MODEL_MODE=gemini)
# opts into "production mode".
GOOGLE_API_KEY=

# Model routing mode. One of: gemma | gemini
#   gemma  - default, runs locally via Ollama, zero egress, no API key
#   gemini - opt-in production mode, requires GOOGLE_API_KEY
GG_MODEL_MODE=gemma

# Ollama server address used when GG_MODEL_MODE=gemma.
OLLAMA_HOST=http://127.0.0.1:11434

# Local Gemma model tag to pull/run via Ollama.
GG_GEMMA_MODEL=gemma2:2b

# Gemini model used when GG_MODEL_MODE=gemini.
GG_GEMINI_MODEL=gemini-flash-latest

# Telemetry exporter target. One of: stdout | cloud
#   stdout - print spans locally (default, no external dependency)
#   cloud  - export to a cloud telemetry backend (requires project config)
OTEL_EXPORTER=stdout

# GCP project ID, required only when OTEL_EXPORTER=cloud or when deploying
# to Cloud Run.
GOOGLE_CLOUD_PROJECT=
