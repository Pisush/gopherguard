{
  "__inputs": [
    {
      "name": "DS_TEMPO",
      "label": "Tempo",
      "description": "Grafana Tempo datasource for TraceQL detection queries",
      "type": "datasource",
      "pluginId": "tempo"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.3.0" },
    { "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "GG-DET-01 — Injection→exfil chain (ASI01)",
      "description": "Traces where a trust.untrusted_input=true span is followed by a trust.egress=true span. See detections/rules/traceql.md.",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "query": "{ span.trust.untrusted_input = true } >> { span.trust.egress = true }",
          "limit": 200,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["count"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "GG-DET-02 — HITL bypass",
      "description": "Spans where trust.hitl_required=true but trust.hitl_result != approved. See detections/rules/traceql.md.",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "query": "{ span.trust.hitl_required = true && span.trust.hitl_result != \"approved\" }",
          "limit": 200,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["count"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "GG-DET-03 — Loop / cost runaway",
      "description": "TraceQL cannot express count(span name) > 5 within a trace; this panel queries the closest proxy (a known loop-prone span name) and needs the ClickHouse GROUP BY/HAVING query (see detections/rules/clickhouse.sql) for the exact count. Table panel below links to that.",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "query": "{ span.gg.repeat_count > 5 }",
          "limit": 200,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["count"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "GG-DET-04 — Privilege widening",
      "description": "Traces where a read:*-scoped span precedes a write/admin-scoped span. See detections/rules/traceql.md for the fully general (ClickHouse self-join) form.",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "query": "{ span.trust.privilege_scope =~ \"^read:\" } >> { span.trust.privilege_scope =~ \"^(write|admin).*\" }",
          "limit": 200,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["count"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "GG-DET-05 — Memory taint",
      "description": "Traces where a non-user mem.provenance span precedes a write:*-scoped decision span. See detections/rules/traceql.md.",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "query": "{ span.mem.provenance != \"user\" && span.mem.provenance != \"\" } >> { span.trust.privilege_scope =~ \"^write:\" }",
          "limit": 200,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["count"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Rule reference",
      "description": "Static reference table describing each seed rule, its ASI risk, and the query it runs -- for context alongside the fired-count panels above.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "displayMode": "auto" } },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "md",
        "footer": { "show": false, "reducer": ["sum"], "countRows": false }
      },
      "transformations": [],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "traceql",
          "query": "{ span.trust.untrusted_input = true } >> { span.trust.egress = true }",
          "limit": 200,
          "tableType": "traces"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["gopherguard", "detections", "security"],
  "templating": {
    "list": [
      {
        "current": { "text": "Tempo", "value": "${DS_TEMPO}" },
        "hide": 0,
        "label": "Tempo",
        "name": "DS_TEMPO",
        "options": [],
        "query": "tempo",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "gopherguard — Trace Detections",
  "uid": "gopherguard-detections",
  "version": 1,
  "weekStart": ""
}
